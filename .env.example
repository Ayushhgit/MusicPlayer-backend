# ── Neon Postgres ────────────────────────────────────────────────────────────
# Get your connection string from https://console.neon.tech
# Format: postgresql+asyncpg://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Spotify ──────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── AI / Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Get your connection string from https://console.upstash.com → your database → Details → "redis://" tab
# Format: rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:6379
